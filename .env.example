# ─── Supabase ────────────────────────────────────────────────
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...  # Supabase > Settings > API > service_role (NÃO a anon key)

# ─── Meta / WhatsApp / Instagram ────────────────────────────
META_VERIFY_TOKEN=qualquer_string_secreta_que_voce_escolher
META_ACCESS_TOKEN=EAAxxxxxxxx    # Meta for Developers > App > WhatsApp > API Setup
META_PHONE_NUMBER_ID=1234567890  # ID do número WhatsApp na Meta

# ─── Claude / Anthropic ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx  # console.anthropic.com > API Keys

# ─── Painel Admin ────────────────────────────────────────────
ADMIN_SECRET=outra_string_secreta  # Crie qualquer string forte (ex: openssl rand -hex 32)
